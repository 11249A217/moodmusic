# ── MoodWave Environment Variables ──────────────────
# Copy this file to .env and fill in your values
# python-dotenv will load it automatically

# Jamendo API client ID
# Register free at https://developer.jamendo.com/
# The default sandbox key works but has lower rate limits
JAMENDO_CLIENT_ID=b6747d04

# Anthropic API key (OPTIONAL)
# Only needed for AI mood-analysis features
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server port (default: 5000)
PORT=5000

# Set to 'development' for hot-reload and debug tracebacks
FLASK_ENV=production

# Admin key to protect the /api/cache/clear endpoint (any random string)
ADMIN_KEY=change_me_to_something_secret
